# X (Twitter) API v2 credentials for the Post-AGI signal-refresh engine.
#
# Copy this file to a SECRETS location OUTSIDE this repository, e.g.:
#   C:\Users\<you>\pap-secrets\.env
# The engine reads it from that path by default; override with X_ENV_PATH if needed.
#
# NEVER commit real values. This repo's .gitignore ignores all .env files.

# --- App-only auth (REQUIRED): unlocks @peterxing's POSTS + REPOSTS in realtime ---
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=

# --- User-context auth (OPTIONAL): additionally unlocks LIKES + BOOKMARKS ---
# OAuth 1.0a user tokens:
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# OAuth 2.0 PKCE (run `node x-auth.js` once to populate the token + refresh; see X-API-SETUP.md):
X_OAUTH2_CLIENT_ID=
X_OAUTH2_CLIENT_SECRET=
X_OAUTH2_TOKEN=
X_OAUTH2_REFRESH=

# --- Optional tuning (defaults shown) ---
# X_ENV_PATH=C:\Users\<you>\pap-secrets\.env
# PAST_WEEK_DAYS=7
# MAX_AGE_DAYS=800
